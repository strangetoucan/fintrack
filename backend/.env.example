# Copy this file to .env and fill in the values.
# In Kubernetes, these are injected via Secret — no .env file is needed.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (MySQL on host):
DATABASE_URL=mysql+pymysql://finance:finance_pass@localhost:3306/finance_budgeter

# Docker Compose (use the compose service name as host):
# DATABASE_URL=mysql+pymysql://finance:finance_pass@db:3306/finance_budgeter

# Production (Kubernetes — set as Secret, not here):
# DATABASE_URL=mysql+pymysql://<user>:<password>@<host>:3306/finance_budgeter

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Dev default (falls back to http://localhost:5173 if unset):
# ALLOWED_ORIGINS=http://localhost:5173

# Production — set to your actual domain:
# ALLOWED_ORIGINS=https://finance.yourdomain.com
